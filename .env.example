# --- Web (Next.js) ---
# Canonical production URL used for metadata, sitemap, robots, and JSON-LD.
# Override this for preview/staging deploys. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://kemisdigital.com

# Required for Supabase auth. Get from Supabase project: Connect > Next.js
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend API URL (browser calls this)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Email address that receives strategy session + payment promo notifications
BOOKING_NOTIFICATION_EMAIL=frontdesk@kemisdigital.com

# Resend (transactional email). Get from https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key

# --- API (FastAPI) ---
# Allowed frontend origins for CORS (comma-separated). Defaults to localhost:3000 and :3001
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional: for AI features (LLM, embeddings, Qdrant)
# OPENAI_API_KEY=sk-...
# LLM_API_KEY=...
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=...
